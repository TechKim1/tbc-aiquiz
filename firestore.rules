rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // MVP: 사내망 운영 기준 — 클라이언트 직접 쓰기 허용
    // Phase 2에서 Firebase Auth 도입 후 role 기반으로 전환 예정

    match /quizSets/{setId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    match /quizSets/{setId}/questions/{questionId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    match /quizSets/{setId}/submissions/{submissionId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    match /leaderboards/{setId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
